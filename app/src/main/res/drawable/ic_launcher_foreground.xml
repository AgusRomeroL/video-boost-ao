<?xml version="1.0" encoding="utf-8"?>
<!--
  Glifo del launcher: cámara de video con destello de 4 puntas, calcado del
  icono de Video Boost de Pixel Camera. Canvas adaptive-icon 108dp; el
  contenido vive en la safe-zone central (~66dp) para sobrevivir a cualquier
  máscara (círculo, squircle, etc.).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group android:translateX="54" android:translateY="54">
        <group android:translateX="-24" android:translateY="-24">
            <!-- Escala del arte 48x48 centrado -->
            <group android:scaleX="1.0" android:scaleY="1.0">
                <!-- Cuerpo de la cámara (rect redondeado) -->
                <path
                    android:fillColor="@color/ic_launcher_glyph"
                    android:pathData="M8,14
                        h20
                        a4,4 0 0 1 4,4
                        v14
                        a4,4 0 0 1 -4,4
                        h-20
                        a4,4 0 0 1 -4,-4
                        v-14
                        a4,4 0 0 1 4,-4 z
                        M9,18 a2.4,2.4 0 0 0 -2.4,2.4 v9.2 a2.4,2.4 0 0 0 2.4,2.4 h18 a2.4,2.4 0 0 0 2.4,-2.4 v-9.2 a2.4,2.4 0 0 0 -2.4,-2.4 z" />
                <!-- Visor / lente triangular -->
                <path
                    android:fillColor="@color/ic_launcher_glyph"
                    android:pathData="M34,20.5 L43,15.5 a1,1 0 0 1 1.5,0.9 v17.2 a1,1 0 0 1 -1.5,0.9 L34,29.5 z" />
                <!-- Destello de 4 puntas (esquina superior izquierda del cuerpo) -->
                <path
                    android:fillColor="@color/ic_launcher_glyph"
                    android:pathData="M13.5,7
                        c0.6,2.6 1.4,3.4 4,4
                        c-2.6,0.6 -3.4,1.4 -4,4
                        c-0.6,-2.6 -1.4,-3.4 -4,-4
                        c2.6,-0.6 3.4,-1.4 4,-4 z" />
                <!-- Destello chico -->
                <path
                    android:fillColor="@color/ic_launcher_glyph"
                    android:pathData="M20.5,9.5
                        c0.35,1.5 0.8,1.95 2.3,2.3
                        c-1.5,0.35 -1.95,0.8 -2.3,2.3
                        c-0.35,-1.5 -0.8,-1.95 -2.3,-2.3
                        c1.5,-0.35 1.95,-0.8 2.3,-2.3 z" />
            </group>
        </group>
    </group>
</vector>
